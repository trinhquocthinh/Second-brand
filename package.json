{
  "name": "second-brain",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"tests/**/*.{ts,tsx}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "dexie": "^4.4.4",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^7.0.0",
    "@types/node": "^24.13.2",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "^10.7.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.11.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.1",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --max-warnings=0",
      "vitest related --run"
    ],
    "src/**/*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
